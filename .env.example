# 深币实例配置模板 — 复制为 .env 后按用户修改
# 多实例：每个用户独立目录 + 独立 .env + 独立 FLASK_PORT

# ── Deepcoin API（每用户一套，切勿共用）──
DEEPCOIN_API_KEY=
DEEPCOIN_API_SECRET=
DEEPCOIN_PASSPHRASE=

# ── Webhook（TradingView 告警 secret，建议每用户不同）──
WEBHOOK_SECRET=change_me_user_secret

# ── 钉钉（可每用户独立机器人，或共用）──
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# ── 网关（多实例必改端口，例如 5004 / 5005 / 5006）──
FLASK_HOST=0.0.0.0
FLASK_PORT=5005

# ── 可选：实例标识（写入日志/health 备注，便于区分）──
INSTANCE_LABEL=deepcoin-user2
